{
  "name": "moon",
  "version": "1.0.0",
  "description": "Self hosted multi-purpose node server",
  "main": "index.js",
  "type": "module",
  "bin": {
    "penguin": "./src/cli/index.js",
    "polarbear": "./src/cli/index.js"
  },
  "imports": {
    "#env": "./src/utils/env.js",
    "#logger": "./src/utils/logger.js"
  },
  "scripts": {
    "start": "sudo systemctl daemon-reload && sudo systemctl restart moon",
    "dev": "NODE_ENV=development node --watch --experimental-specifier-resolution=node src/index",
    "lint": "eslint . --fix --ext .js",
    "build": "node esbuild",
    "restart": "npm run build && npm start",
    "postinstall": "./scripts/postinstall.sh",
    "uninstall": "./scripts/uninstall.sh",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "cron": "^3.1.6",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "esbuild": "^0.19.10",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.2",
    "prettier": "^3.1.1"
  }
}