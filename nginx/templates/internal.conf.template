# add_header Alt-Svc 'h3=":443"; ma=86400';
server {
    listen 443 ssl;
    server_name photos.smileyfam.me;
    access_log off;

    ssl_certificate /etc/letsencrypt/live/smileyfam.me/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/smileyfam.me/privkey.pem;

    include /etc/nginx/conf.d/immich.conf;
    location / {
        proxy_pass http://immich;
    }
}

server {
    listen 443 ssl;
    server_name music.smileyfam.me;
    access_log off;

    ssl_certificate /etc/letsencrypt/live/smileyfam.me/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/smileyfam.me/privkey.pem;

    location / {
        include /etc/nginx/conf.d/proxy.conf;
        proxy_pass http://navidrome;
    }
}

server {
    listen 443 ssl;
    server_name sso.smileyfam.me;
    access_log off;

    location / {
        grpc_pass grpc://zitadel;
        grpc_set_header Host $host;
    }
}

server {
    listen 443 ssl;
    server_name auth.smileyfam.me;
    access_log off;

    location / {
        include /etc/nginx/conf.d/proxy.conf;
        proxy_pass http://authentik;
        proxy_set_header Connection $connection_upgrade;
    }
}

